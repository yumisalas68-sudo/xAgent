# ── ScrapeBadger (comma-separated, one per account) ──────────────────────────
SCRAPEBADGER_API_KEYS=key_account1,key_account2,key_account3

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Railway sets this automatically — set manually for local testing ───────────
WEBHOOK_BASE_URL=https://your-app-name.railway.app
